    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.3.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "tsx": "^4.22.0",
    "typescript": "^6.0.2",
