DATABASE_URL="dev.db"

# Telemetry provider — defaults to local OpenObserve. The Settings dialog
# can flip this at runtime via a cookie; this env var is the fallback when
# no cookie is set.
# TELEMETRY_PROVIDER=app-insights

# OpenObserve overrides (defaults work zero-config against the docker image).
# OO_BASE_URL=http://localhost:5080
# OO_USER=root@example.com
# OO_PASS=Complexpass#123

# Application Insights — paste the ApplicationId from the connection string
# and an API key created in the resource's "API Access" blade.
# APPLICATIONINSIGHTS_APP_ID=
# APPLICATIONINSIGHTS_API_KEY=

# Custom span field mappings — comma-separated column names to check in
# addition to the standard OTel / ag_ui fields. Set these when your SDK emits
# non-standard attribute names. All users on this deployment pick them up
# automatically; no per-user configuration needed.
# CUSTOM_SESSION_ID_FIELDS=agentcontext_threadid
# CUSTOM_USER_ID_FIELDS=userid
