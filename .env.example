DATABASE_URL="dev.db"

# Telemetry provider — defaults to local OpenObserve. The Settings dialog
# can flip this at runtime via a cookie; this env var is the fallback when
# no cookie is set.
# TELEMETRY_PROVIDER=app-insights

# OpenObserve overrides (defaults work zero-config against the docker image).
# OO_BASE_URL=http://localhost:5080
# OO_USER=root@example.com
# OO_PASS=Complexpass#123
# OO_ORG=default
# OO_STREAM=default

# Application Insights (resource ID uses Azure AD; or set APP_ID + API_KEY for legacy)
# APPLICATIONINSIGHTS_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/microsoft.insights/components/<name>
# APPLICATIONINSIGHTS_APP_ID=
# APPLICATIONINSIGHTS_API_KEY=

# MCP registry (/mcp) — JSON array of servers loupe mirrors and lints. Each ref:
# id, name, endpoint (streamable-http tools/list URL), transport, optional
# ownerTeam / ownerContact. Empty/unset → the /mcp list is empty.
# MCP_REGISTRY_REFS_JSON=[{"id":"listings","name":"Listings","endpoint":"http://localhost:3333/mcp","transport":"streamable-http","ownerTeam":"listings"}]

# Dataset runs (/datasets) — replay inputs against your agent. ENDPOINT is the
# agent's OpenAI-compatible /v1/responses URL; AGENT is the entity id to invoke
# (discover it from <endpoint host>/v1/entities).
# DATASET_RUN_ENDPOINT=http://localhost:4280/v1/responses
# DATASET_RUN_AGENT=agent_in_memory_sandbox-agent_<id>

# LLM judge (/evals) — grades runs via the Vercel AI SDK. Provider is inferred
# from JUDGE_MODEL (claude* → Anthropic, azure/* → Azure OpenAI, else OpenAI);
# set the matching key.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# JUDGE_MODEL=gpt-4o-mini
# Azure OpenAI: pick an azure/* model in /evals (deployment name must match the
# model id, e.g. deploy gpt-4o-mini as "gpt-4o-mini") plus the vars below.
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_RESOURCE_NAME=my-resource   # or AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Behind an APIM gateway: set AZURE_OPENAI_APIM_KEY to auth via the
# Ocp-Apim-Subscription-Key header (api-key then stays a placeholder).
# AZURE_OPENAI_APIM_KEY=...

# Extensions — fork-local SQL Server (AgentTasks registry → /tasks enrichment).
# ADO.NET connection string; unset = no-op (telemetry-only /tasks).
# EXT_SQL_CONNECTION_STRING=Server=host,1433;Initial Catalog=db;User Id=u;password=p;

# Extensions — fork-local Teammate auth for /datasets runs. Routing is per-dataset:
# any run whose endpoint URL is a company-scoped Teammate chat endpoint
# (.../api/companies/{id}/chat) goes through the authenticated path instead of the
# generic OpenAI Responses endpoint — set it as DATASET_RUN_ENDPOINT (above) or per
# dataset. The EXT_TEAMMATE_* creds mint a real *user* token via the Paycor password
# grant, auto-refreshed (refresh tokens rotate). The company id in the URL must be one
# the user actually has Teammate access to. Creds unset = no-op (upstream path).
# DATASET_RUN_ENDPOINT=http://localhost:5065/api/companies/959370/chat
# EXT_TEAMMATE_ENVS powers the /datasets env dropdown ("Label=baseUrl" pairs); the
# picker appends /api/companies/{id}/chat using EXT_TEAMMATE_COMPANY_ID as the default.
# EXT_TEAMMATE_ENVS=Local=http://localhost:5065,Dev=https://<dev-host>
# EXT_TEAMMATE_COMPANY_ID=959370
# EXT_TEAMMATE_TOKEN_URL=https://<paycor-secure-host>/accounts/api/v2/authtoken
# EXT_TEAMMATE_CLIENT_ID=TeammateService
# EXT_TEAMMATE_CLIENT_SECRET=
# EXT_TEAMMATE_USERNAME=
# EXT_TEAMMATE_PASSWORD=

# Extensions — MCP registry (Azure Table Storage)
# EXT_MCP_REGISTRY_ACCOUNT_NAME=your-storage-account
# EXT_MCP_REGISTRY_ACCOUNT_KEY=...
# EXT_MCP_REGISTRY_TABLE_NAME=McpServerRegistry
